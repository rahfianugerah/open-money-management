---
import AppShell from '../../components/AppShell.astro';
---

<AppShell pageTitle="Currency Settings" activePath="/settings/currencies">
  <section class="grid-2">
    <article class="card panel">
      <h2 class="panel-title">Add or Update Currency</h2>
      <form id="currency-form" class="form-grid">
        <div class="form-grid columns-2">
          <div class="form-row">
            <label class="field-label" for="currency-code">Code</label>
            <input id="currency-code" name="code" class="input" maxlength="3" required />
          </div>
          <div class="form-row">
            <label class="field-label" for="currency-name">Name</label>
            <input id="currency-name" name="name" class="input" required />
          </div>
        </div>

        <div class="form-grid columns-2">
          <div class="form-row">
            <label class="field-label" for="currency-symbol">Symbol</label>
            <input id="currency-symbol" name="symbol" class="input" />
          </div>
          <div class="form-row">
            <label class="field-label" for="currency-default">Default Currency</label>
            <select id="currency-default" name="isDefault">
              <option value="false">No</option>
              <option value="true">Yes</option>
            </select>
          </div>
        </div>

        <button class="btn-primary" type="submit">Save Currency</button>
      </form>
    </article>

    <article class="card panel">
      <h2 class="panel-title">Manual Conversion Rate</h2>
      <form id="rate-form" class="form-grid">
        <div class="form-grid columns-2">
          <div class="form-row">
            <label class="field-label" for="base-code">Base Code</label>
            <input id="base-code" name="baseCode" class="input" maxlength="3" required />
          </div>
          <div class="form-row">
            <label class="field-label" for="target-code">Target Code</label>
            <input id="target-code" name="targetCode" class="input" maxlength="3" required />
          </div>
        </div>

        <div class="form-row">
          <label class="field-label" for="rate-value">Rate</label>
          <input id="rate-value" name="rate" class="input" type="number" step="0.000001" min="0.000001" required />
        </div>

        <button class="btn-primary" type="submit">Save Rate</button>
      </form>
    </article>
  </section>

  <section class="card panel">
    <h2 class="panel-title">Exchange API Configuration</h2>
    <p class="helper-text" style="margin-bottom: 12px;">
      Keep disabled to stay fully offline. Enable only if you want optional online rate sync.
    </p>
    <form id="provider-form" class="form-grid">
      <div class="form-grid columns-2">
        <div class="form-row">
          <label class="field-label" for="provider-enabled">Enabled</label>
          <select id="provider-enabled" name="enabled">
            <option value="false">No</option>
            <option value="true">Yes</option>
          </select>
        </div>

        <div class="form-row">
          <label class="field-label" for="provider-name">Provider</label>
          <input id="provider-name" name="provider" class="input" placeholder="exchangerate.host" />
        </div>
      </div>

      <div class="form-grid columns-2">
        <div class="form-row">
          <label class="field-label" for="provider-url">Base URL</label>
          <input id="provider-url" name="baseUrl" class="input" placeholder="https://api.exchangerate.host" />
        </div>

        <div class="form-row">
          <label class="field-label" for="provider-key">API Key (optional)</label>
          <input id="provider-key" name="apiKey" class="input" />
        </div>
      </div>

      <div class="inline-actions">
        <button class="btn-primary" type="submit">Save Provider Settings</button>
        <button id="sync-rates-btn" type="button">Sync Rates From Provider</button>
      </div>
    </form>
  </section>

  <section class="grid-2">
    <article class="card panel">
      <h2 class="panel-title">Currencies</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Code</th>
              <th>Name</th>
              <th>Symbol</th>
              <th>Default</th>
              <th>Updated</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody id="currencies-body"></tbody>
        </table>
      </div>
    </article>

    <article class="card panel">
      <h2 class="panel-title">Rate Update History</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Base</th>
              <th>Target</th>
              <th>Rate</th>
              <th>Created</th>
              <th>Updated</th>
            </tr>
          </thead>
          <tbody id="rates-body"></tbody>
        </table>
      </div>
    </article>
  </section>

  <p id="settings-error" class="error-text" hidden></p>
  <p id="settings-success" class="success-text" hidden></p>
</AppShell>

<script type="module">
  import {
    ApiError,
    listCurrencies,
    createCurrency,
    updateCurrency,
    listRates,
    upsertRate,
    getProviderConfig,
    saveProviderConfig,
    syncRates,
  } from '/lib/client-api.js';

  const currenciesBody = document.getElementById('currencies-body');
  const ratesBody = document.getElementById('rates-body');

  const currencyForm = document.getElementById('currency-form');
  const codeInput = document.getElementById('currency-code');
  const nameInput = document.getElementById('currency-name');
  const symbolInput = document.getElementById('currency-symbol');
  const defaultInput = document.getElementById('currency-default');

  const rateForm = document.getElementById('rate-form');

  const providerForm = document.getElementById('provider-form');
  const providerEnabled = document.getElementById('provider-enabled');
  const providerName = document.getElementById('provider-name');
  const providerUrl = document.getElementById('provider-url');
  const providerKey = document.getElementById('provider-key');
  const syncRatesButton = document.getElementById('sync-rates-btn');

  const errorEl = document.getElementById('settings-error');
  const successEl = document.getElementById('settings-success');

  let cachedCurrencies = [];

  function showStatus({ error = '', success = '' }) {
    errorEl.hidden = !error;
    successEl.hidden = !success;
    errorEl.textContent = error;
    successEl.textContent = success;
  }

  function formatDate(value) {
    return new Date(value).toLocaleString('en-US', {
      year: 'numeric',
      month: 'short',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit',
    });
  }

  function renderCurrencies(currencies) {
    if (!currencies || currencies.length === 0) {
      currenciesBody.innerHTML =
        '<tr><td colspan="6" class="helper-text">No currencies configured.</td></tr>';
      return;
    }

    currenciesBody.innerHTML = currencies
      .map(
        (currency) => `
          <tr>
            <td>${currency.code}</td>
            <td>${currency.name}</td>
            <td>${currency.symbol || '-'}</td>
            <td>${currency.is_default ? 'Yes' : 'No'}</td>
            <td>${formatDate(currency.updated_at)}</td>
            <td>
              <button
                type="button"
                data-action="make-default"
                data-currency-id="${currency.id}"
                ${currency.is_default ? 'disabled' : ''}
              >
                Make Default
              </button>
            </td>
          </tr>
        `
      )
      .join('');
  }

  function renderRates(rates) {
    if (!rates || rates.length === 0) {
      ratesBody.innerHTML = '<tr><td colspan="5" class="helper-text">No rates recorded.</td></tr>';
      return;
    }

    ratesBody.innerHTML = rates
      .map(
        (rate) => `
          <tr>
            <td>${rate.base_code}</td>
            <td>${rate.target_code}</td>
            <td>${Number(rate.rate).toFixed(6)}</td>
            <td>${formatDate(rate.created_at)}</td>
            <td>${formatDate(rate.updated_at)}</td>
          </tr>
        `
      )
      .join('');
  }

  async function refreshCurrenciesAndRates() {
    const [currencies, rates] = await Promise.all([listCurrencies(), listRates()]);
    cachedCurrencies = currencies;
    renderCurrencies(currencies);
    renderRates(rates);
  }

  currencyForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    showStatus({});

    try {
      await createCurrency({
        code: codeInput.value.trim().toUpperCase(),
        name: nameInput.value.trim(),
        symbol: symbolInput.value.trim(),
        isDefault: defaultInput.value === 'true',
      });

      currencyForm.reset();
      showStatus({ success: 'Currency saved successfully.' });
      await refreshCurrenciesAndRates();
    } catch (error) {
      showStatus({
        error: error instanceof ApiError ? error.message : 'Failed to save currency.',
      });
    }
  });

  rateForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    showStatus({});

    const form = new FormData(rateForm);

    try {
      await upsertRate({
        baseCode: String(form.get('baseCode')).trim().toUpperCase(),
        targetCode: String(form.get('targetCode')).trim().toUpperCase(),
        rate: Number(form.get('rate')),
      });

      rateForm.reset();
      showStatus({ success: 'Rate saved successfully.' });
      await refreshCurrenciesAndRates();
    } catch (error) {
      showStatus({
        error: error instanceof ApiError ? error.message : 'Failed to save rate.',
      });
    }
  });

  providerForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    showStatus({});

    try {
      await saveProviderConfig({
        enabled: providerEnabled.value === 'true',
        provider: providerName.value.trim(),
        baseUrl: providerUrl.value.trim(),
        apiKey: providerKey.value,
      });

      showStatus({ success: 'Provider settings saved.' });
    } catch (error) {
      showStatus({
        error: error instanceof ApiError ? error.message : 'Failed to save provider settings.',
      });
    }
  });

  syncRatesButton?.addEventListener('click', async () => {
    showStatus({});

    try {
      const result = await syncRates({ baseCode: 'USD' });
      showStatus({ success: `Synced ${result.updatedCount} rates from provider.` });
      await refreshCurrenciesAndRates();
    } catch (error) {
      showStatus({
        error: error instanceof ApiError ? error.message : 'Failed to sync rates.',
      });
    }
  });

  currenciesBody?.addEventListener('click', async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLButtonElement)) {
      return;
    }

    if (target.dataset.action !== 'make-default') {
      return;
    }

    const currencyId = target.dataset.currencyId;
    if (!currencyId) {
      return;
    }

    const currency = cachedCurrencies.find((item) => item.id === currencyId);
    if (!currency) {
      return;
    }

    showStatus({});

    try {
      await updateCurrency(currencyId, {
        isDefault: true,
      });

      showStatus({ success: `${currency.code} is now the default currency.` });
      await refreshCurrenciesAndRates();
    } catch (error) {
      showStatus({
        error: error instanceof ApiError ? error.message : 'Failed to update default currency.',
      });
    }
  });

  async function bootstrap() {
    // Wait for AppShell auth bootstrap so protected API calls don't race token validation.
    if (window.__ommAuthReady) {
      await window.__ommAuthReady;
    }

    const providerConfig = await getProviderConfig();

    providerEnabled.value = String(Boolean(providerConfig.enabled));
    providerName.value = providerConfig.provider || '';
    providerUrl.value = providerConfig.baseUrl || '';
    providerKey.value = providerConfig.apiKey || '';

    await refreshCurrenciesAndRates();
  }

  bootstrap().catch((error) => {
    showStatus({
      error: error instanceof ApiError ? error.message : 'Failed to load currency settings.',
    });
  });
</script>
