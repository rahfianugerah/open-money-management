---
import AuthLayout from '../layouts/AuthLayout.astro';
---

<AuthLayout title="Open Money Management">
	<main class="auth-page">
		<section class="card auth-card">
			<h1 class="auth-title">Open Money Management</h1>
			<p class="auth-subtitle">Checking authentication and redirecting...</p>
		</section>
	</main>
</AuthLayout>

<script type="module">
	import { ensureSession, hasAuthToken } from '/lib/client-api.js';

	// Root route always resolves to either login or dashboard based on token validity.
	if (!hasAuthToken()) {
		window.location.href = '/login';
	} else {
		try {
			await ensureSession();
			window.location.href = '/dashboard';
		} catch {
			window.location.href = '/login';
		}
	}
</script>
