<div class="chatbot-panel card" id="chatbot-panel" aria-live="polite">
  <div class="chat-header">
    <strong>Local Finance Assistant</strong>
    <button type="button" id="chatbot-close-btn">Close</button>
  </div>
  <div class="chat-history" id="chat-history"></div>
  <form class="chat-input" id="chat-form">
    <input class="input" id="chat-input" name="prompt" placeholder="Ask about your finances..." />
    <button class="btn-primary" type="submit">Send</button>
  </form>
</div>
<button class="chatbot-fab" id="chatbot-toggle-btn" type="button" aria-label="Toggle chatbot">
  Chat
</button>

<script type="module">
  import { askChatbot, ApiError } from '/lib/client-api.js';

  const STORAGE_KEY = 'omm-chat-history-v1';
  const toggleButton = document.getElementById('chatbot-toggle-btn');
  const closeButton = document.getElementById('chatbot-close-btn');
  const panel = document.getElementById('chatbot-panel');
  const historyEl = document.getElementById('chat-history');
  const chatForm = document.getElementById('chat-form');
  const chatInput = document.getElementById('chat-input');

  function loadHistory() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) {
        return [];
      }

      const parsed = JSON.parse(raw);
      if (!Array.isArray(parsed)) {
        return [];
      }

      return parsed.slice(-40);
    } catch {
      return [];
    }
  }

  function saveHistory(history) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(history.slice(-40)));
  }

  function renderMessage(message) {
    const row = document.createElement('div');
    row.className = `chat-bubble ${message.role === 'user' ? 'user' : 'assistant'}`;
    row.textContent = message.content;
    historyEl.appendChild(row);
    historyEl.scrollTop = historyEl.scrollHeight;
  }

  function renderHistory(history) {
    historyEl.innerHTML = '';
    history.forEach(renderMessage);
  }

  let history = loadHistory();
  renderHistory(history);

  function openPanel() {
    panel.classList.add('open');
    chatInput.focus();
  }

  function closePanel() {
    panel.classList.remove('open');
  }

  toggleButton?.addEventListener('click', () => {
    if (panel.classList.contains('open')) {
      closePanel();
    } else {
      openPanel();
    }
  });

  closeButton?.addEventListener('click', closePanel);

  chatForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const prompt = chatInput.value.trim();
    if (!prompt) {
      return;
    }

    const userMessage = { role: 'user', content: prompt };
    history.push(userMessage);
    renderMessage(userMessage);
    saveHistory(history);

    chatInput.value = '';
    chatInput.disabled = true;

    try {
      const response = await askChatbot({
        prompt,
        history: history.slice(-20),
      });

      const assistantMessage = { role: 'assistant', content: response.text };
      history.push(assistantMessage);
      renderMessage(assistantMessage);
      saveHistory(history);
    } catch (error) {
      const fallback =
        error instanceof ApiError
          ? `Chatbot request failed: ${error.message}`
          : 'Unable to contact local chatbot service.';

      const assistantMessage = { role: 'assistant', content: fallback };
      history.push(assistantMessage);
      renderMessage(assistantMessage);
      saveHistory(history);
    } finally {
      chatInput.disabled = false;
      chatInput.focus();
    }
  });
</script>
