---
import Layout from '../layouts/Layout.astro';
import ChatbotWidget from './ChatbotWidget.astro';

const { pageTitle, activePath } = Astro.props;

const navItems = [
  { href: '/dashboard', label: 'Dashboard' },
  { href: '/balances', label: 'Balances' },
  { href: '/settings/currencies', label: 'Currency Settings' },
];
---

<Layout title={`${pageTitle} | Open Money Management`}>
  <div class="app-shell">
    <aside class="sidebar card panel">
      <div class="brand">Open Money</div>
      <p class="helper-text" style="margin-top: 8px;">Offline money management workspace</p>
      <nav class="nav-list" aria-label="Main navigation">
        {
          navItems.map((item) => (
            <a href={item.href} class={`nav-item ${activePath === item.href ? 'active' : ''}`}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </aside>

    <main class="main-content">
      <header class="topbar card">
        <h1 class="topbar-title">{pageTitle}</h1>
        <div class="topbar-user">
          <span class="badge">Public Mode</span>
        </div>
      </header>
      <section class="page-grid">
        <slot />
      </section>
    </main>
  </div>

  <ChatbotWidget />
</Layout>
